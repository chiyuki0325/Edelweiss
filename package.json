    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@guiiai/logg": "^1.2.11",
    "alien-signals": "^3.1.2",
    "better-sqlite3": "^11.7.0",
    "diff": "^8.0.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.0",
    "grammy": "^1.35.0",
    "immer": "^10.1.1",
    "sharp": "^0.34.5",
    "telegram": "^2.26.22",
    "valibot": "^1.2.0",
    "xsai": "^0.4.4"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.24.0"
    }
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^2.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@velin-dev/core": "^0.3.4",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.0.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "tsdown": "^0.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
